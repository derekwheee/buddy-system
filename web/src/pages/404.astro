---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Buddy System" description="That page isn't on the pitch.">
    <section
        class="section container stack"
        style="text-align:center; padding-block: calc(var(--p) * 12);"
    >
        <span class="label muted">Error 404</span>
        <h1>Not on the pitch</h1>
        <p class="muted" style="margin-inline:auto;">
            That page couldn't be found. Nothing you do here is permanent — head back and try again.
        </p>
        <p><a href="/" class="btn btn--primary">Back to home</a></p>
    </section>
</BaseLayout>
