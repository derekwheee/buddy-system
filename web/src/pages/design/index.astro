---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Plate from '../../components/Plate.astro';

// 03 — Color system
const surfaces = [
    {
        var: '--ink',
        name: 'Soldermask',
        role: 'Primary dark surface — hardware, packaging, hero screens.',
        val: '--ink · #17181b',
        border: false,
    },
    {
        var: '--paper',
        name: 'Paper',
        role: 'Reading surface — docs, manuals, light UI. Warm like breadboard ABS.',
        val: '--paper · #f4f3ee',
        border: true,
    },
    {
        var: '--silk',
        name: 'Silkscreen',
        role: 'Linework and type on dark surfaces. Pure white, always opaque.',
        val: '--silk · #ffffff',
        border: true,
    },
    {
        var: '--copper',
        name: 'Copper',
        role: 'Reserved. Marks community / third-party cards and open-hardware callouts.',
        val: '--copper · #c29a4d',
        border: false,
    },
];
const families = [
    {
        var: '--fam-ctl',
        name: 'CTL · Control',
        role: 'Pots, switches, faders, sensors — things you touch.',
        val: 'oklch(0.70 0.17 50)',
    },
    {
        var: '--fam-snd',
        name: 'SND · Sound',
        role: 'Oscillators, filters, amps, speakers — things you hear. Also the interaction color on screens: pressing things makes sound.',
        val: 'oklch(0.86 0.17 98)',
    },
    {
        var: '--fam-dat',
        name: 'DAT · Data',
        role: 'MIDI, USB, CV, sync — things that talk.',
        val: 'oklch(0.70 0.15 155)',
    },
    {
        var: '--fam-lgc',
        name: 'LGC · Logic',
        role: 'Clocks, sequencers, gates — things that decide.',
        val: 'oklch(0.67 0.13 240)',
    },
    {
        var: '--fam-uty',
        name: 'UTY · Utility',
        role: 'Breadboards, blanks, adapters — things that help.',
        val: 'oklch(0.67 0.13 305)',
    },
    {
        var: '--fam-pwr',
        name: 'PWR · Power',
        role: 'Supplies and rails. Shares the red rail hue — power is power everywhere.',
        val: 'oklch(0.62 0.18 28)',
    },
];

// 12 — Registry
const registry = [
    { id: 'BS-CTL-01', name: 'Pots Buddy', fam: 'ctl', label: 'CTL', status: 'SHIPPING' },
    { id: 'BS-CTL-02', name: 'Switch Buddy', fam: 'ctl', label: 'CTL', status: 'SHIPPING' },
    { id: 'BS-DAT-01', name: 'MIDI Buddy', fam: 'dat', label: 'DAT', status: 'SHIPPING' },
    { id: 'BS-SND-01', name: 'Amp Buddy', fam: 'snd', label: 'SND', status: 'PROTOTYPE' },
    { id: 'BS-SND-02', name: 'Filter Buddy', fam: 'snd', label: 'SND', status: 'PROTOTYPE' },
    { id: 'BS-LGC-01', name: 'Clock Buddy', fam: 'lgc', label: 'LGC', status: 'PLANNED' },
    { id: 'BS-UTY-04', name: 'Blank Buddy', fam: 'uty', label: 'UTY', status: 'SHIPPING' },
];

const sectionNav = [
    ['principles', 'Principles'],
    ['color', 'Color'],
    ['type', 'Type'],
    ['grid', 'Grid'],
    ['icons', 'Icons'],
    ['applied', 'Applied'],
    ['evolution', 'Evolution'],
];
---

<BaseLayout
    title="Design System — Buddy System"
    description="A design language you can breadboard: a fixed pitch, two surfaces, labels that say what things do, and color that means something."
>
    <div class="ds">
        <!-- in-page section nav -->
        <div class="ds-subnav">
            <div class="container ds-subnav__inner">
                <span class="label">Design System v0.1</span>
                <nav>
                    {sectionNav.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
                </nav>
            </div>
        </div>

        <!-- ========== COVER ========== -->
        <header class="ds-cover">
            <div class="container stack">
                <Plate fill="BUDDY" rest="SYSTEM" tone="on-ink" size="lg" />
                <h1>A design language you can breadboard</h1>
                <p class="ds-deck">
                    Design system proposal v0.1 — a working document. Everything in here follows the
                    same logic as the hardware: a fixed pitch, two surfaces, labels that say what
                    things do, and color that means something.
                </p>
                <div class="ds-cover-meta mono">
                    <span>STATUS — <b>DRAFT FOR REVIEW</b></span>
                    <span>DATE — <b>JUN 2026</b></span>
                    <span>SCOPE — <b>HARDWARE · PRINT · SCREEN</b></span>
                </div>
            </div>
            <div class="rails" aria-hidden="true"></div>
        </header>

        <!-- ========== 01 PRINCIPLES ========== -->
        <section id="principles" class="ds-sec ds-sec--paper">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="01" rest="PRINCIPLES" />
                    <span class="label muted">Five rules · everything else is derived</span>
                </header>
                <h2>Core principles</h2>
                <p class="ds-intro">
                    Buddy System's identity isn't a style applied to the product — it's the
                    product's own logic, written down. Each principle below maps to a physical fact
                    about the hardware.
                </p>
                <div class="princ-grid">
                    <div class="princ">
                        <span class="princ__num mono">P1</span><h3>Everything on the pitch</h3><p>
                            The breadboard's 2.54&nbsp;mm hole spacing is the master unit. On screen
                            and in print, 1P&nbsp;=&nbsp;10&nbsp;px. All spacing, sizing, and
                            alignment snaps to whole or half multiples of P. If it isn't on the
                            pitch, it isn't Buddy System.
                        </p>
                    </div>
                    <div class="princ">
                        <span class="princ__num mono">P2</span><h3>Labels are the logo</h3><p>
                            The brand mark is a silkscreen label: a two-cell boxed plate with the
                            first cell filled. It costs nothing to print on a PCB, and it scales
                            from a 6&nbsp;mm card label to a billboard. We don't have a logo and a
                            labeling system — they're the same thing.
                        </p>
                    </div>
                    <div class="princ">
                        <span class="princ__num mono">P3</span><h3>Color is wiring</h3><p>
                            Hue is never decoration. Six family colors identify what a card does;
                            red and blue are reserved for power rails; black and white are surfaces.
                            If a color appears, it's carrying information — like a jumper wire.
                        </p>
                    </div>
                    <div class="princ">
                        <span class="princ__num mono">P4</span><h3>Two surfaces only</h3><p>
                            Soldermask black and breadboard white. Hardware, packaging, and hero
                            screens live on black; documentation and reading surfaces live on warm
                            white. Nothing lives on gradients, photos-as-backgrounds, or grays in
                            between.
                        </p>
                    </div>
                    <div class="princ princ--full">
                        <div>
                            <span class="princ__num mono">P5</span><h3>
                                Friendly words, serious lines
                            </h3>
                        </div><p>
                            Approachability comes from naming and voice — every module is somebody's
                            Buddy, every guide talks like a patient friend at a workbench. The
                            geometry stays precise and technical. We never soften the drawing to
                            seem friendly; we soften the words. This is how the system reads as
                            welcoming without ever reading as a toy.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========== 02 MOOD ========== -->
        <section id="mood" class="ds-sec ds-sec--ink">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="02" rest="MOOD" tone="on-ink" />
                    <span class="label ds-mcap-ink">Breadboard vernacular</span>
                </header>
                <h2>Visual themes</h2>
                <p class="ds-intro">
                    The mood is the workbench at its best: a clean black panel, a fresh white
                    breadboard, a handful of colored jumpers, and the feeling that nothing you do is
                    permanent. Lab equipment that wants to be touched.
                </p>
                <div class="mood-words">
                    {
                        [
                            ['Calibrated', 'not corporate'],
                            ['Hands-on', 'not hacker-movie'],
                            ['Labelled', 'not skeuomorphic'],
                            ['Reversible', 'not precious'],
                            ['Playful', 'not toy-like'],
                            ['Open', 'not unfinished'],
                        ].map(([yes, not]) => (
                            <div class="mood-pair">
                                <>
                                    <span class="mood-yes">{yes}</span>
                                    <span class="mood-not">{not}</span>
                                </>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- ========== 03 COLOR ========== -->
        <section id="color" class="ds-sec ds-sec--paper">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="03" rest="COLOR" />
                    <span class="label muted">Six hues · six jobs · nothing spare</span>
                </header>
                <h2>Color system</h2>
                <p class="ds-intro">
                    Two surfaces, one metal, and six functional hues — one per card family, all
                    matched in weight so no family outranks another. Family color appears only in
                    small, meaningful doses: a keybar, a pin-1 mark, a chip, a tag.
                </p>

                <div class="swatches">
                    {
                        [...surfaces, ...families].map((s) => (
                            <div class="swatch-row">
                                <span
                                    class="sw"
                                    style={`background: var(${s.var}); ${'border' in s && s.border ? 'border:2px solid var(--paper-3);' : ''}`}
                                />
                                <span class="sw-name">{s.name}</span>
                                <span class="sw-role muted">{s.role}</span>
                                <span class="sw-val mono">{s.val}</span>
                            </div>
                        ))
                    }
                </div>

                <div class="rules">
                    <div class="rule">
                        <h4>Small doses</h4><p>
                            Family color never fills a layout. Keybars, chips, pin-1 marks,
                            underlines — accents under 10% of any composition. The brand stays black
                            &amp; white with colored wiring.
                        </p>
                    </div>
                    <div class="rule">
                        <h4>Rails are sacred</h4><p>
                            Red + blue paired lines mean power rails and appear only as edge/footer
                            motifs. In wiring diagrams, red is always +V and black is always ground.
                            Never use rail red for errors or marketing.
                        </p>
                    </div>
                    <div class="rule">
                        <h4>One family per zone</h4><p>
                            A card, a chapter, a product page belongs to one family and uses one
                            hue. Multiple hues appear together only in system-level views — legends,
                            the base unit, the family band.
                        </p>
                    </div>
                    <div class="rule">
                        <h4>Matched weight</h4><p>
                            All six family hues sit at matched lightness and chroma in OKLCH. New
                            hues (if ever) must join the same weight class. No neons, no pastels.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========== 04 TYPOGRAPHY ========== -->
        <section id="type" class="ds-sec ds-sec--paper">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="04" rest="TYPE" />
                    <span class="label muted">Barlow superfamily + IBM Plex Mono</span>
                </header>
                <h2>Typography</h2>
                <p class="ds-intro">
                    The Barlow superfamily keeps a DIN flavor — low-contrast, slightly squared,
                    signage-bred — but it's open-licensed, so the same files ship in silkscreen art,
                    manuals, the website, and community remixes without seat licenses. IBM Plex Mono
                    handles everything that refers to the machine: pin names, designators, code,
                    captions.
                </p>

                <div class="type-row">
                    <div class="t-display">Patch. Play. Undo.</div><div class="t-spec mono">
                        DISPLAY<br />Barlow Semi Cond 800<br />UPPERCASE · 0.95 LH<br />64–96PX / 0P
                        TRACK
                    </div>
                </div>
                <div class="type-row">
                    <div class="t-h1">Build sound from scratch</div><div class="t-spec mono">
                        HEADING<br />Barlow Semi Cond 700<br />UPPERCASE · 1.05 LH<br />24–52PX
                    </div>
                </div>
                <div class="type-row">
                    <div class="t-label">Cutoff / Resonance</div><div class="t-spec mono">
                        LABEL<br />Barlow Semi Cond 700<br />UPPERCASE · +0.14EM TRACK<br />13–16PX
                        · PANELS + UI
                    </div>
                </div>
                <div class="type-row">
                    <div class="t-body">
                        Body text is Barlow at reading sizes — plain, roomy, and lowercase. It
                        explains; it never shouts. Maximum measure is 64 characters, line height
                        1.6.
                    </div><div class="t-spec mono">
                        BODY<br />Barlow 400/500<br />SENTENCE CASE<br />14–17PX · 1.6 LH
                    </div>
                </div>
                <div class="type-row">
                    <div class="t-mono mono">
                        ROW 12 · A–E&nbsp;&nbsp;&nbsp;BS-SND-02 · REV A&nbsp;&nbsp;&nbsp;FIG
                        3.2&nbsp;&nbsp;&nbsp;+5V GND
                    </div><div class="t-spec mono">
                        TECHNICAL<br />IBM Plex Mono 400–600<br />PINS · REFS · CAPTIONS · CODE<br
                        />9–13PX · TRACKED
                    </div>
                </div>

                <div class="rules rules--2">
                    <div class="rule">
                        <h4>Case carries tone</h4><p>
                            UPPERCASE condensed = the machine speaking (panels, headings, labels).
                            Lowercase Barlow = a person speaking (guidance, marketing copy). Mono =
                            the system's data. Three voices, instantly distinguishable.
                        </p>
                    </div>
                    <div class="rule">
                        <h4>Three voices</h4><p>
                            The condensed display face, the roomy body face, and the technical mono
                            never blur together. Each does one job, so a reader always knows whether
                            the system, a person, or the data is talking.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========== 05 GRID ========== -->
        <section id="grid" class="ds-sec ds-sec--paper">
            <div class="container">
                <span class="jumper" style="--fam: var(--fam-ctl);" aria-hidden="true"
                    ><i></i><i></i></span
                >
                <header class="ds-head">
                    <Plate fill="05" rest="GRID" />
                    <span class="label muted">1P = 2.54 mm = 10 px</span>
                </header>
                <h2>The pitch grid</h2>
                <p class="ds-intro">
                    One unit governs everything: P, the breadboard pitch. Hardware is literally
                    built on it; print and screen borrow it. Designers stop inventing spacing — they
                    count holes.
                </p>

                <div class="pitch-demo">
                    <div class="pitch-card">
                        <h4>Spacing scale — whole pitches only</h4>
                        <div class="space-scale">
                            {
                                [
                                    ['0.5P · 5PX — hairline', 5],
                                    ['1P · 10PX — element gap', 10],
                                    ['2P · 20PX — group gap', 20],
                                    ['4P · 40PX — block padding', 40],
                                    ['8P · 80PX — section break', 80],
                                ].map(([t, w]) => (
                                    <div class="space-item">
                                        <>
                                            <span class="mono">{t}</span>
                                            <span class="space-bar" style={`width:${w}px;`} />
                                        </>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                    <div class="pitch-card">
                        <h4>The dot field</h4>
                        <div class="dotfield-demo">
                            <span class="mono">1P PITCH · DOTS MARK THE HOLES</span>
                        </div>
                        <p class="mono ds-cap">
                            Background texture for dark surfaces. Always at true 1P scale, always
                            subtle — a surface you could plug into.
                        </p>
                    </div>
                </div>

                <div class="rules rules--2">
                    <div class="rule">
                        <h4>Page grids</h4><p>
                            Web: 12 columns, 2P gutters, content max 108P (1080px). Print: 8-column
                            on A5 manuals with a 4P margin ruler. Faceplates: controls center on
                            whole-P positions, matching real drill coordinates.
                        </p>
                    </div>
                    <div class="rule">
                        <h4>The ruler motif</h4><p>
                            Breadboard column numbers (1, 5, 10, 15…) appear as marginalia on
                            documentation pages and long web pages — wayfinding borrowed straight
                            from the board.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========== 06 ICONS ========== -->
        <section id="icons" class="ds-sec ds-sec--ink">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="06" rest="ICONS" tone="on-ink" />
                    <span class="label ds-mcap-ink">Filled · chunky · silkscreen-safe</span>
                </header>
                <h2>Iconography</h2>
                <p class="ds-intro">
                    Icons are drawn like silkscreen: solid fills and fat 5px strokes on a 4P (40px)
                    grid, with knockouts instead of thin lines. Every icon must survive being
                    printed 5&nbsp;mm wide in one color on a PCB — that constraint is the style.
                </p>

                <div class="icon-grid">
                    <div class="icon-cell">
                        <svg width="40" height="40" viewBox="0 0 40 40"
                            ><circle cx="20" cy="20" r="16" fill="currentColor"></circle><rect
                                x="17.5"
                                y="5"
                                width="5"
                                height="14"
                                rx="2"
                                fill="var(--ink-2)"></rect></svg
                        ><span class="mono">KNOB</span>
                    </div>
                    <div class="icon-cell">
                        <svg width="40" height="40" viewBox="0 0 40 40"
                            ><circle cx="20" cy="20" r="16" fill="currentColor"></circle><circle
                                cx="20"
                                cy="20"
                                r="7"
                                fill="var(--ink-2)"></circle></svg
                        ><span class="mono">JACK</span>
                    </div>
                    <div class="icon-cell">
                        <svg width="40" height="40" viewBox="0 0 40 40"
                            ><path
                                d="M4 30 V10 H20 V30 H36 V10"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="5"
                                stroke-linecap="square"></path></svg
                        ><span class="mono">WAVE</span>
                    </div>
                    <div class="icon-cell">
                        <svg width="40" height="40" viewBox="0 0 40 40"
                            ><rect x="9" y="12" width="22" height="16" rx="2" fill="currentColor"
                            ></rect><rect x="12" y="5" width="4" height="6" fill="currentColor"
                            ></rect><rect x="18" y="5" width="4" height="6" fill="currentColor"
                            ></rect><rect x="24" y="5" width="4" height="6" fill="currentColor"
                            ></rect><rect x="12" y="29" width="4" height="6" fill="currentColor"
                            ></rect><rect x="18" y="29" width="4" height="6" fill="currentColor"
                            ></rect><rect x="24" y="29" width="4" height="6" fill="currentColor"
                            ></rect></svg
                        ><span class="mono">CHIP</span>
                    </div>
                    <div class="icon-cell icon-cell--tint" style="color: var(--fam-dat);">
                        <svg width="40" height="40" viewBox="0 0 40 40"
                            ><path
                                d="M7 30 C7 8 33 8 33 30"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="5"
                                stroke-linecap="round"></path><rect
                                x="3"
                                y="29"
                                width="8"
                                height="8"
                                rx="2"
                                fill="currentColor"></rect><rect
                                x="29"
                                y="29"
                                width="8"
                                height="8"
                                rx="2"
                                fill="currentColor"></rect></svg
                        ><span class="mono">JUMPER</span>
                    </div>
                    <div class="icon-cell">
                        <svg width="40" height="40" viewBox="0 0 40 40"
                            ><rect x="6" y="13" width="24" height="14" rx="2" fill="currentColor"
                            ></rect><rect
                                x="32"
                                y="17"
                                width="4"
                                height="6"
                                rx="1"
                                fill="currentColor"></rect></svg
                        ><span class="mono">POWER</span>
                    </div>
                </div>

                <div class="rules rules--2">
                    <div class="rule">
                        <h4>Construction rules</h4><p>
                            40px grid, 5px strokes, square or round caps — never both in one icon.
                            Interior detail is knocked out, not outlined. Minimum two, maximum five
                            shapes per icon.
                        </p>
                    </div>
                    <div class="rule">
                        <h4>Color behavior</h4><p>
                            Icons inherit currentColor: silk on dark, ink on paper, family hue only
                            when the icon stands for that family (like the green jumper above).
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ========== 07–10 APPLIED ========== -->
        <section id="applied" class="ds-sec ds-sec--paper">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="07" rest="APPLIED" />
                    <span class="label muted">From faceplate to website</span>
                </header>
                <h2>Applying the language</h2>
                <p class="ds-intro">
                    The same grammar — plate, keybar, rails, dot field — carries from the PCB to the
                    page. Four surfaces, one vocabulary.
                </p>

                <div class="applied-grid">
                    <div class="applied">
                        <h3>PCB silkscreen</h3><p>
                            The faceplate is the brand's home turf. Every card shares one anatomy: a <b
                                >[FUNCTION][BUDDY]</b
                            > name plate top-center with the designator in mono below it (BS-SND-02 ·
                            REV A), a family-hue keybar at the top edge echoed on the pin-1 square, and
                            related controls boxed into thin outlined zones with a mono label breaking
                            the top border.
                        </p>
                    </div>
                    <div class="applied">
                        <h3>Documentation</h3><p>
                            Docs are called <b>patches</b>, not lessons — each one ends with sound.
                            Pages live on paper white with a column-number ruler up top and power
                            rails at the foot. Numbered plates mark steps; every part is referenced
                            in mono exactly as printed on the hardware. The voice is second person,
                            present tense — "that buzz is yours."
                        </p>
                    </div>
                    <div class="applied">
                        <h3>Website</h3><p>
                            The site is a faceplate that scrolls: a black hero on the dot field, the
                            family legend as a permanent navigation band, then paper-white sections
                            that read like the manual. Interactive elements light up in <b
                                >SND yellow</b
                            > — on this brand, pressing things makes sound.
                        </p>
                    </div>
                    <div class="applied">
                        <h3>Packaging</h3><p>
                            The box is printed like the product: matte black board, one-color white
                            silkscreen, family hue on the spine so a shelf of cards color-codes
                            itself. The first patch is printed inside the lid — you can make a sound
                            before you've thrown away the packaging. Honest materials: uncoated
                            kraft, single ink, no lamination.
                        </p>
                    </div>
                </div>
                <p class="mono ds-cap ds-cap--note">
                    Interactive faceplate, manual-spread, and landing-page mockups live in the
                    source design system; they are re-created natively across this site rather than
                    embedded here.
                </p>
            </div>
        </section>

        <!-- ========== 11 MOTIFS ========== -->
        <section id="motifs" class="ds-sec ds-sec--ink">
            <div class="container">
                <header class="ds-head">
                    <Plate fill="11" rest="MOTIFS" tone="on-ink" />
                    <span class="label ds-mcap-ink">The recurring cast</span>
                </header>
                <h2>Recurring motifs</h2>
                <p class="ds-intro">
                    Six elements repeat across every surface. If a layout contains two of these, it
                    reads as Buddy System — no logo required.
                </p>

                <div class="motif-grid">
                    <div class="motif">
                        <div class="motif__demo">
                            <Plate fill="ANY" rest="THING" tone="on-ink" size="sm" />
                        </div><h4>The plate</h4><p>
                            Two cells, first filled. Names products, numbers steps, marks sections.
                            The wordmark is just the plate wearing its own name.
                        </p>
                    </div>
                    <div class="motif">
                        <div class="motif__demo"><span class="m-keybar"></span></div><h4>
                            The keybar
                        </h4><p>
                            A family-hue bar on the top edge of any card, tile, box, or page header.
                            Color as a key, not a wash.
                        </p>
                    </div>
                    <div class="motif">
                        <div class="motif__demo">
                            <span class="rails m-rails" aria-hidden="true"></span>
                        </div><h4>The rails</h4><p>
                            Paired red/blue lines marking edges and endings — footers, box bottoms,
                            certificate borders. Power runs along the edge.
                        </p>
                    </div>
                    <div class="motif">
