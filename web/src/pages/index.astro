---
import BaseLayout from '../layouts/BaseLayout.astro';

// Card grid (teaser → /features/)
const tiles = [
    {
        fam: 'ctl',
        plate: ['KNOB', 'BUDDY'],
        h: 'Six smooth knobs',
        p: 'Six pots broken out one-to-one. Turn anything into a control surface.',
        a: '6× linear pot',
        b: '10-bit read',
        ref: 'BD-CTL-01',
        status: 'SHIPPING',
        controls: 'pots',
    },
    {
        fam: 'ctl',
        plate: ['SWITCH', 'BUDDY'],
        h: 'Six clean toggles',
        p: "Gates, modes, and mischief. Debounced so your code doesn't have to be.",
        a: '6× SPDT',
        b: 'hardware debounce',
        ref: 'BD-CTL-02',
        status: 'SHIPPING',
        controls: 'switch',
    },
    {
        fam: 'dat',
        plate: ['MIDI', 'BUDDY'],
        h: 'In, out, and through',
        p: 'MIDI on real DIN jacks, opto-isolated and level-shifted for you.',
        a: 'DIN-5 in / out',
        b: 'opto-isolated',
        ref: 'BD-DAT-01',
        status: 'SHIPPING',
        controls: 'midi',
    },
    {
        fam: 'snd',
        plate: ['LINE', 'BUDDY'],
        h: 'Circuit to sound',
        p: 'A speaker amp with a volume knob. The shortest path from signal to ears.',
        a: '2W class-D',
        b: 'onboard speaker',
        ref: 'BD-SND-01',
        status: 'PROTOTYPE',
        controls: 'amp',
    },
    {
        fam: 'lgc',
        plate: ['OLED', 'BUDDY'],
        h: 'A steady pulse',
        p: 'Tempo, divisions, and triggers — the heartbeat for sequencers and steps.',
        a: '1–300 BPM',
        b: '4 division outs',
        ref: 'BD-LGC-01',
        status: 'PLANNED',
        controls: 'clock',
    },
    {
        fam: 'uty',
        plate: ['ENCODER', 'BUDDY'],
        h: 'Bare grid, your rules',
        p: "A prototyping grid wired to the bay. Make the card we didn't — then share it.",
        a: '0.1" perfboard',
        b: 'full pin breakout',
        ref: 'BD-UTY-04',
        status: 'SHIPPING',
        controls: 'blank',
    },
];
---

<BaseLayout
    title="Buddy System — Build synths with a buddy"
    description="A big, friendly breadboard plus plug-in Buddy Cards for knobs, MIDI, sound, logic, and power. Prototype real instruments in an afternoon — no soldering."
    bodyClass="on-ink"
>
    <!-- ============ HERO ============ -->
    <header class="sec hero dots-dark" id="top" data-screen-label="Hero">
        <div class="wrap">
            <div class="hero-kicker reveal">
                <span class="mcap mcap-ink">MODULAR · SOLDERLESS · OPEN HARDWARE</span>
            </div>
            <h1 class="reveal d1">Build synths with a <em>buddy</em></h1>
            <p class="sub reveal d2">
                A big, friendly breadboard plus plug-in Buddy Cards for knobs, MIDI, sound, logic,
                and power. Prototype real instruments in an afternoon — no soldering, nothing you
                can't undo.
            </p>
            <div class="hero-ctas reveal d3">
                <a class="btn" href="#waitlist">Stay in sync <span class="arrow">→</span></a>
                <a class="btn ghost" href="#cards">See how it works</a>
            </div>

            <!-- composed base-unit stand-in (silkscreen placeholder) -->
            <div class="hero-stage reveal d3">
                <div class="board" aria-label="Buddy System base unit — illustrative placeholder">
                    <div class="board-top">
                        <span class="plate" style="font-size: 12px;"
                            ><span class="cell fill"><span>BUDDY</span></span><span class="cell"
                                >SYSTEM</span
                            ></span
                        >
                        <span class="designator">BD-000 · BASE UNIT · REV A</span>
                        <span class="board-mountrow"><i></i><i></i></span>
                    </div>
                    <div class="slot-row">
                        <div class="face" style="--fam: var(--fam-ctl);">
                            <div class="keybar"></div>
                            <div class="fp-name">
                                <span class="plate" style="font-size:9px;"
                                    ><span class="cell fill"><span>KNOB</span></span><span
                                        class="cell">BUDDY</span
                                    ></span
                                >
                            </div>
                            <div class="fp-ref">BD-KNB-01</div>
                            <div class="fp-controls">
                                <div class="ctrl-row">
                                    <span class="knob sm"></span><span class="knob sm"></span>
                                </div>
                                <div class="ctrl-row">
                                    <span class="knob sm"></span><span class="knob sm"></span>
                                </div>
                                <div class="ctrl-row">
                                    <span class="knob sm"></span><span class="knob sm"></span>
                                </div>
                            </div>
                            <div class="fp-foot">1 2 3 4 5 6</div>
                        </div>
                        <div class="face" style="--fam: var(--fam-dat);">
                            <div class="keybar"></div>
                            <div class="fp-name">
                                <span class="plate" style="font-size:9px;"
                                    ><span class="cell fill"><span>MIDI</span></span><span
                                        class="cell">BDY</span
                                    ></span
                                >
                            </div>
                            <div class="fp-ref">BD-MIDI-01</div>
                            <div class="fp-controls">
                                <span class="jack"></span><span class="jack"></span><span class="jack"></span>
                            </div>
                            <div class="fp-foot">IN · THRU · OUT</div>
                        </div>
                        <div class="face" style="--fam: var(--fam-snd);">
                            <div class="keybar"></div>
                            <div class="fp-name">
                                <span class="plate" style="font-size:9px;"
                                    ><span class="cell fill"><span>LINE</span></span><span
                                        class="cell">BUDDY</span
                                    ></span
                                >
                            </div>
                            <div class="fp-ref">BD-LIN-01</div>

                            <div class="fp-controls">
                                <div class="ctrl-row">
                                    <span class="jack"></span>
                                    <div class="fp-controls">
                                        <span class="jack"></span><span class="knob sm"></span>
                                    </div>
                                    <span class="jack"></span>
                                </div>
                            </div>
                            <div class="fp-foot">IN · PHN · OUT</div>
                        </div>
                        <div class="face" style="--fam: var(--fam-lgc);">
                            <div class="keybar"></div>
                            <div class="fp-name">
                                <span class="plate" style="font-size:9px;"
                                    ><span class="cell fill"><span>SWITCH</span></span><span
                                        class="cell">BUDDY</span
                                    ></span
                                >
                            </div>
                            <div class="fp-ref">BD-SWC-01</div>
                            <div class="fp-controls">
                                <div class="ctrl-row">
                                    <span class="toggle"></span><span class="toggle"></span>
                                </div>
                                <div class="ctrl-row">
                                    <span class="toggle"></span><span class="toggle"></span>
                                </div>
                                <div class="ctrl-row">
                                    <span class="toggle"></span><span class="toggle"></span>
                                </div>
                            </div>
                            <div class="fp-foot">1 2 3 4 5 6</div>
                        </div>
                        <div class="breadboard">
                            <span class="bb-label">BREADBOARD · 1P PITCH</span>
                            <div class="bb-dots"></div>
                            <span class="bb-label" style="text-align:right;">A–E · 1…30</span>
                        </div>
                    </div>
                    <div class="board-rails"><div class="rails"></div></div>
                </div>
            </div>
        </div>
    </header>

    <!-- ============ MEET THE BUDDIES ============ -->
    <section class="sec on-paper" id="cards" data-screen-label="Meet the Buddies">
        <div class="wrap">
            <div class="sec-head">
                <div class="lead">
                    <span class="eyebrow">01 — THE CARDS</span>
                    <h2>Meet the Buddies</h2>
                </div>
            </div>

            <div class="card-grid">
                {
                    tiles.map((t, i) => (
                        <article
                            class={`tile reveal${i % 3 ? ` d${i % 3}` : ''}`}
                            style={`--fam: var(--fam-${t.fam});`}
                        >
                            <div class="tile-face">
                                <div class="keybar kb-draw" />
                                <div class="tile-controls">
                                    {t.controls === 'pots' && (
                                        <div class="ctrl-row">
                                            <span class="knob" />
                                            <span class="knob" />
                                            <span class="knob" />
                                        </div>
                                    )}
                                    {t.controls === 'switch' && (
                                        <Fragment>
                                            <span class="toggle on" />
                                            <span class="toggle" />
                                            <span class="toggle on" />
                                            <span class="toggle" />
                                        </Fragment>
                                    )}
                                    {t.controls === 'midi' && (
                                        <Fragment>
                                            <span class="jack" />
                                            <span class="jack" />
                                        </Fragment>
                                    )}
                                    {t.controls === 'amp' && (
                                        <Fragment>
                                            <span class="speaker" />
                                            <span class="knob" />
                                        </Fragment>
                                    )}
                                    {t.controls === 'clock' && (
                                        <Fragment>
                                            <span class="knob" />
                                            <div class="ctrl-row">
                                                <span class="jack" />
                                                <span class="jack" />
                                            </div>
                                        </Fragment>
                                    )}
                                    {t.controls === 'blank' && <span class="gridzone" />}
                                </div>
                            </div>
                            <div class="tile-body">
                                <span class="plate">
                                    <>
                                        <span class="cell fill">
                                            <span>{t.plate[0]}</span>
                                        </span>
                                        <span class="cell">{t.plate[1]}</span>
                                    </>
                                </span>
                                <h3>{t.h}</h3>
                                <p>{t.p}</p>
                                <div class="tile-meta">
                                    <div>
                                        <div class="specline">
                                            <>
                                                <span>{t.a}</span>
                                                <b>{t.b}</b>
                                            </>
                                        </div>
                                    </div>
                                </div>
                                <div class="tile-foot">
                                    <>
                                        <span class="ref">{t.ref}</span>
                                        <span class="status">{t.status}</span>
                                    </>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>

            <div class="cards-more reveal">
                <a class="btn ghost" href="/features/"
                    >See all card families <span class="arrow">→</span></a
                >
            </div>
        </div>
    </section>

    <!-- ============ HOW IT WORKS ============ -->
    <section class="sec on-paper2" id="how" data-screen-label="How it works">
        <div class="wrap">
            <div class="sec-head">
                <div class="lead">
                    <span class="eyebrow">02 — THE LOOP</span>
                    <h2>Plug. Patch. Play.</h2>
                </div>
                <span class="aside">Three moves, endlessly repeatable. Nothing is permanent.</span>
            </div>

            <div class="how-grid">
                <div class="how-connect" style="left: 16%; right: 50%;"></div>
                <div class="how-connect" style="left: 50%; right: 16%;"></div>

                <div class="how-step reveal">
                    <svg class="step-icon" viewBox="0 0 48 48" fill="none"
                        ><rect x="6" y="14" width="22" height="20" rx="2" fill="currentColor"
                        ></rect><rect
                            x="30"
                            y="20"
                            width="12"
                            height="8"
                            rx="1.5"
                            fill="currentColor"></rect><rect
                            x="11"
                            y="8"
                            width="4"
                            height="8"
                            fill="currentColor"></rect><rect
                            x="19"
                            y="8"
                            width="4"
                            height="8"
                            fill="currentColor"></rect></svg
                    >
                    <div class="step-plate">
                        <span class="plate"
                            ><span class="cell fill"><span>1</span></span><span class="cell"
                                >PLUG</span
                            ></span
                        >
                    </div>
                    <h3>Pick your buddies</h3>
                    <p>
                        Slot any card into any bay. The keyed connector means there's no wrong way
                        in — and no card you can damage by trying.
                    </p>
                </div>

                <div class="how-step reveal d1">
                    <svg class="step-icon" viewBox="0 0 48 48" fill="none"
                        ><path
                            d="M8 36 C8 12 40 12 40 36"
                            stroke="currentColor"
                            stroke-width="5"
                            stroke-linecap="round"></path><rect
                            x="3"
                            y="34"
                            width="10"
                            height="10"
                            rx="2"
                            fill="currentColor"></rect><rect
                            x="35"
                            y="34"
                            width="10"
                            height="10"
                            rx="2"
                            fill="currentColor"></rect></svg
                    >
                    <div class="step-plate">
                        <span class="plate"
                            ><span class="cell fill"><span>2</span></span><span class="cell"
                                >PATCH</span
                            ></span
                        >
                    </div>
                    <h3>Wire it up</h3>
                    <p>
                        Follow a patch from the field manual, or freestyle with jumpers on the
                        breadboard. Every pin is labelled exactly as the firmware names it.
                    </p>
                </div>

                <div class="how-step reveal d2">
                    <svg class="step-icon" viewBox="0 0 48 48" fill="none"
                        ><circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="5"
                        ></circle><path d="M20 16 L33 24 L20 32 Z" fill="currentColor"></path></svg
                    >
                    <div class="step-plate">
                        <span class="plate"
                            ><span class="cell fill"><span>3</span></span><span class="cell"
                                >PLAY</span
                            ></span
                        >
                    </div>
                    <h3>Make it yours</h3>
                    <p>
                        Tweak, rewire, break, rebuild. Nothing is soldered and everything is
                        reversible — so the only way to fail is to stop.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============ FEATURED PATCHES ============ -->
    <section class="sec on-ink dots-dark" id="patches" data-screen-label="Featured patches">
        <div class="wrap">
            <div class="sec-head">
                <div class="lead">
                    <span class="eyebrow">03 — START SOMEWHERE</span>
                    <h2>Patches to start with</h2>
                </div>
                <span class="aside"
                    >Guided builds that end in sound — usually under an hour, always undoable.</span
                >
            </div>

            <div class="patch-grid">
                <article class="patch reveal" style="--fam: var(--fam-snd);">
                    <div class="patch-viz">
                        <svg
                            width="180"
                            height="80"
                            viewBox="0 0 180 80"
                            fill="none"
                            aria-hidden="true"
                            ><path
                                d="M0 40 Q22.5 0 45 40 T90 40 T135 40 T180 40"
                                stroke="var(--fam-snd)"
                                stroke-width="3"></path></svg
                        >
                    </div>
                    <div class="patch-body">
                        <span class="patch-tag">SND · PATCH 01</span>
                        <h3>Your first beep</h3>
                        <p>
                            One oscillator, one knob, one speaker. Make a sound you control in ten
                            minutes flat.
                        </p>
                        <div class="patch-meta">
                            <span>⏱ 10 MIN</span><span>◇ 4 JUMPERS</span><span>★ BEGINNER</span>
                        </div>
                    </div>
                </article>

                <article class="patch reveal d1" style="--fam: var(--fam-lgc);">
                    <div class="patch-viz">
                        <svg
                            width="180"
                            height="80"
                            viewBox="0 0 180 80"
                            fill="none"
                            aria-hidden="true"
                            ><path
                                d="M0 56 H30 V24 H60 V56 H90 V24 H120 V56 H150 V24 H180"
                                stroke="var(--fam-lgc)"
                                stroke-width="3"></path></svg
                        >
                    </div>
                    <div class="patch-body">
                        <span class="patch-tag">LGC · PATCH 04</span>
                        <h3>A clock you can feel</h3>
                        <p>
                            Drive a blinking gate with the Clock Buddy, then divide it into a
                            rhythm.
                        </p>
                        <div class="patch-meta">
                            <span>⏱ 25 MIN</span><span>◇ 7 JUMPERS</span><span>★ EASY</span>
                        </div>
                    </div>
                </article>

                <article class="patch reveal d2" style="--fam: var(--fam-dat);">
                    <div class="patch-viz">
                        <svg
                            width="180"
                            height="80"
                            viewBox="0 0 180 80"
                            fill="none"
                            aria-hidden="true"
                            ><rect
                                x="20"
                                y="30"
                                width="20"
                                height="20"
                                rx="3"
                                stroke="var(--fam-dat)"
                                stroke-width="3"></rect><rect
                                x="140"
                                y="30"
                                width="20"
                                height="20"
                                rx="3"
                                stroke="var(--fam-dat)"
                                stroke-width="3"></rect><path
                                d="M40 40 H140"
                                stroke="var(--fam-dat)"
                                stroke-width="3"
                                stroke-dasharray="6 6"></path></svg
                        >
                    </div>
                    <div class="patch-body">
                        <span class="patch-tag">DAT · PATCH 09</span>
                        <h3>Play it with MIDI</h3>
                        <p>
                            Bring a keyboard in over MIDI and let it drive the pitch of your first
                            beep.
                        </p>
                        <div class="patch-meta">
                            <span>⏱ 40 MIN</span><span>◇ 9 JUMPERS</span><span>★ MEDIUM</span>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- ============ TECHNICAL SPECS ============ -->
    <section class="sec on-paper" id="specs" data-screen-label="Technical specs">
        <div class="wrap">
            <div class="sec-head">
                <div class="lead">
                    <span class="eyebrow">04 — THE NUMBERS</span>
                    <h2>Built on the pitch</h2>
                </div>
                <span class="aside"
                    >One unit governs everything: P, the 2.54&nbsp;mm breadboard pitch. Hardware is
                    built on it; the bus rides it.</span
                >
            </div>

            <div class="spec-grid reveal">
                <div class="spec-cell">
                    <span class="spec-keybar" style="--fam: var(--fam-uty);"></span>
                    <span class="sval">2.54<span class="u">mm</span></span>
                    <span class="slabel">Pitch · 1P</span>
                    <span class="snote"
                        >The master unit. Every hole, pad, and drill lands on it.</span
                    >
                </div>
                <div class="spec-cell">
                    <span class="spec-keybar" style="--fam: var(--fam-dat);"></span>
                    <span class="sval">6<span class="u">pin</span></span>
                    <span class="slabel">Universal bay</span>
                    <span class="snote">One keyed connector. Every card fits every bay.</span>
                </div>
                <div class="spec-cell">
                    <span class="spec-keybar" style="--fam: var(--fam-pwr);"></span>
                    <span class="sval">3V3<span class="u"> / 5V</span></span>
                    <span class="slabel">Power rails</span>
                    <span class="snote">Both rails distributed on the bus, with shared ground.</span
                    >
                </div>
                <div class="spec-cell">
                    <span class="spec-keybar" style="--fam: var(--fam-lgc);"></span>
                    <span class="sval">RS-485</span>
                    <span class="slabel">Buddy Bus</span>
                    <span class="snote">Half-duplex multidrop. Up to six addressable cards.</span>
                </div>
            </div>

            <div class="pinout reveal d1" aria-label="Buddy Bus pinout">
                <div class="pin lgc">
                    <span class="pnum">1</span><span
                        ><span class="psig">SLOT</span><span class="pmeaning">ANALOG ID</span></span
                    >
                </div>
                <div class="pin dat">
                    <span class="pnum">2</span><span
                        ><span class="psig">BUS&nbsp;A</span><span class="pmeaning">RS-485 A</span
                        ></span
                    >
                </div>
                <div class="pin dat">
                    <span class="pnum">3</span><span
                        ><span class="psig">BUS&nbsp;B</span><span class="pmeaning">RS-485 B</span
                        ></span
                    >
                </div>
                <div class="pin pwr">
                    <span class="pnum">4</span><span
                        ><span class="psig">3V3</span><span class="pmeaning">+3.3 V</span></span
                    >
                </div>
                <div class="pin pwr">
                    <span class="pnum">5</span><span
                        ><span class="psig">5V</span><span class="pmeaning">+5 V</span></span
                    >
                </div>
                <div class="pin gnd">
                    <span class="pnum">6</span><span
                        ><span class="psig">GND</span><span class="pmeaning">GROUND</span></span
                    >
                </div>
            </div>
            <p class="spec-foot">
                FULL ELECTRICAL + MECHANICAL DETAIL IN <a href="/docs/technical-spec/"
                    >BD-SPEC-100</a
                > · PROTOCOL IN <a href="/docs/bus-protocol/">BD-SPEC-200</a>
            </p>
        </div>
    </section>

    <!-- ============ ECOSYSTEM / OPEN ============ -->
    <section class="sec on-paper2" id="open" data-screen-label="Open hardware">
        <div class="wrap">
            <div class="eco-grid">
                <div class="reveal">
                    <span class="eyebrow">05 — OPEN BY DESIGN</span>
                    <h2 class="eco-title">Make the card we didn't</h2>
                    <p class="intro" style="margin-top: calc(var(--p) * 2);">
                        The bus, the pinout, and the protocol are public. Anyone can design a Buddy
                        Card, and the design language is built to be borrowed — start from the
                        plate, keybar, and rails and you're already on-brand.
                    </p>

                    <div class="eco-points">
                        <div class="eco-point">
                            <span class="ep-mark"
                                ><svg width="22" height="22" viewBox="0 0 40 40"
                                    ><rect
                                        x="6"
                                        y="13"
                                        width="24"
                                        height="14"
                                        rx="2"
                                        fill="currentColor"></rect><rect
                                        x="32"
                                        y="17"
                                        width="4"
                                        height="6"
                                        rx="1"
                                        fill="currentColor"></rect></svg
                                ></span
                            >
                            <div>
                                <h4>One bus, fully documented</h4>
                                <p>
                                    Six pins, one protocol, no NDA. The spec that the official cards
                                    use is the spec you get.
                                </p>
                            </div>
                        </div>
                        <div class="eco-point">
                            <span class="ep-mark" style="color: var(--copper);"
                                ><svg width="20" height="20" viewBox="0 0 40 40"
                                    ><circle
                                        cx="20"
                                        cy="20"
                                        r="15"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="5"></circle><circle
                                        cx="20"
                                        cy="20"
                                        r="5"
                                        fill="currentColor"></circle></svg
                                ></span
                            >
                            <div>
                                <h4>Copper marks community cards</h4>
                                <p>
                                    Third-party cards wear a copper keybar and a BD-X designator.
                                    Adoption into a family is an event — the card earns its color.
                                </p>
                            </div>
                        </div>
                        <div class="eco-point">
                            <span class="ep-mark"
                                ><svg width="20" height="20" viewBox="0 0 40 40"
                                    ><path
                                        d="M4 30 V10 H20 V30 H36 V10"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="5"
                                        stroke-linecap="square"></path></svg
                                ></span
                            >
                            <div>
                                <h4>Tokens ship with hardware</h4>
                                <p>
                                    Design tokens are versioned with board revisions. When the
                                    silkscreen changes, the website changes from the same commit.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="eco-card reveal d1">
                    <span class="copper-bar"></span>
                    <span class="eyebrow">THE REGISTRY · SINGLE SOURCE OF TRUTH</span>
                    <div style="margin-top: calc(var(--p) * 2);">
                        <div class="reg-line">
                            <span class="desig">BD-CTL-01</span><span class="fname">Pots Buddy</span
                            ><span class="chip" style="--fam: var(--fam-ctl);">CTL</span>
                        </div>
